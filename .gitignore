# Ignore any local reading_list directory and everything under it
**/reading_list/

# macOS
.DS_Store

# Claude Code local (per-user) settings
.claude/settings.local.json

# Claude Code skills — local/per-user, not shared via the repo
.claude/skills/

# Local session log maintained by the end-session skill (git log is the real history)
session_log.md

# Cached CV PDFs + text extractions used by the scraper skill. Local per-clone;
# not committed. Re-download on demand if lost.
data/cv_cache/

# data/extracted: track only the network layer. Raw per-prof scrape outputs and
# audit/state files stay local — regenerate them with the scraper if lost.
data/extracted/*.csv
!data/extracted/authors.csv
!data/extracted/papers_canonical.csv
!data/extracted/paper_authors.csv
